.denominator-params-container
  width 100%
  display flex
  flex-wrap wrap
  padding 0 8px
  border-top 1px solid rgba(0, 0, 0, 0.12)

  .denominator-params-header
    width 100%
    display flex
    align-items center
    justify-content space-between
    padding 8px 0

    .denominator-params-title
      font-size 12px
      font-weight 500
      text-transform uppercase
      color rgba(0, 0, 0, 0.54)

  .denominator-params-status
    width 100%
    padding 0 8px 8px
    font-size 12px
    color rgba(0, 0, 0, 0.54)
    font-style italic
