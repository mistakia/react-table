@import '../styles/tokens.styl'

.table-search
  flex 0 0 auto
  height 32px
  width 32px
  margin-right $rt_space_sm
  position relative
  border 1px solid transparent
  border-radius $rt_radius_sm
  transition width 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms, border-color $rt_transition, box-shadow $rt_transition
  overflow hidden
  align-items center
  justify-content flex-start

  input
  .table-search-clear
    opacity 0

  &:hover
    background $rt_bg
    border 1px solid $rt_border

  &.-open
    display flex
    background $rt_bg
    border 1px solid $rt_accent
    box-shadow $rt_focus_ring
    width 250px

    .table-search-icon
      display none

    input
    .table-search-clear
      opacity 1

  &.-disabled
    opacity 0.5
    pointer-events none

.table-search-icon
  display flex
  align-items center
  justify-content center
  width 32px
  height 32px
  cursor pointer
  flex 0 0 32px
  color $rt_text_muted

.table-search-input
  height 32px
  width 200px
  border-radius $rt_radius_sm
  padding-left $rt_space_lg
  font-size $rt_font_size_md
  color $rt_text
  flex 1
  border 0

.table-search-clear
  flex 0 0 auto
  cursor pointer
  padding 0 $rt_space_xs
  display flex
  align-items center
  justify-content center
  height 32px
  color $rt_text_muted
  &:hover
    color $rt_accent
