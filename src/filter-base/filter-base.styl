@import '../styles/variables.styl'
@import '../styles/tokens.styl'

.table-filter-item
  position relative
  border-radius $rt_radius_sm
  padding $rt_space_xs $rt_space_sm
  margin $rt_space_sm $rt_space_xs !important
  display flex
  flex-direction column
  background $rt_bg
  cursor pointer
  user-select none
  min-height 32px
  flex 0 0 auto
  border 1px solid transparent
  transition border-color $rt_transition, background $rt_transition
  &:hover
    background $rt_bg_hover
    border 1px solid $rt_border_subtle
    .table-filter-item-label
      color $rt_accent

.table-filter-item-label
  font-size $rt_font_size_micro
  font-weight $rt_font_weight_label
  color $rt_text_muted
  text-transform uppercase
  letter-spacing 0.06em
  line-height 1.4

.table-filter-item-dropdown
  background $rt_bg
  min-width 150px
  display flex
  flex-direction column
  border-radius $rt_radius
  border 1px solid $rt_modal_border
  box-shadow $rt_modal_shadow

.table-filter-item-dropdown-body
  display flex
  flex-direction column
  max-height 250px
  overflow hidden
  overflow-y scroll
  border-radius 0 0 $rt_radius_sm $rt_radius_sm

.table-filter-item-dropdown-item
  flex 1
  padding $rt_space_sm
  display flex
  align-items center
  cursor pointer
  gap $rt_space_sm
  color $rt_text

  &.selected
    background $rt_accent_subtle

  &:hover
    background $rt_bg_hover

  .MuiCheckbox-root
    padding 0

  .MuiSvgIcon-root
    width 16px
    height 16px

  .MuiInputBase-root
    height 24px
    width 60px

.table-filter-item-dropdown-item-label
  flex 1

.table-filter-item-dropdown-section
  border-bottom 1px solid $rt_divider

.table-filter-item-dropdown-item-tag
  font-size $rt_font_size_micro
  color $rt_text_muted
  background $rt_bg_subtle
  padding 0.1875rem 0.375rem
  border-radius $rt_radius_sm
  display flex
  align-items center
  justify-content center
  text-transform uppercase
  letter-spacing 0.06em
  font-weight $rt_font_weight_label

.table-filter-item-selection
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  max-width 126px
  color $rt_text
  font-size $rt_font_size_sm

.table-filter-item-dropdown-head
  display flex
  border-bottom 1px solid $rt_divider
  justify-content flex-start
  padding $rt_space_sm
  gap $rt_space

  .controls-button
    background $rt_button_hover_bg
    border 1px solid $rt_border_subtle
    color $rt_text_muted
    &:hover
      background $rt_button_hover_bg_strong
      color $rt_text

    &.close
      margin-left auto

.table-filter-item-dropdown-action
  background $rt_button_hover_bg
  border 1px solid $rt_border_subtle
  padding 0.25rem 0.5rem
  border-radius $rt_radius_sm
  display flex
  justify-content center
  align-items center
  color $rt_text_muted
  transition background $rt_transition, color $rt_transition
  &:hover
    background $rt_button_hover_bg_strong
    color $rt_text

@media (max-width 800px)
  .table-filter-item-dropdown-action
    min-height 32px
    min-width 48px
