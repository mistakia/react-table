.table-view-modal.MuiModal-root
  z-index 10000

.table-view-modal-paper.MuiPaper-root
  border-radius 10px
  box-shadow 0 24px 60px rgba(0, 0, 0, 0.2)
  overflow hidden

.table-view-modal-title.MuiDialogTitle-root
  display flex
  align-items center
  justify-content space-between
  font-size 16px
  font-weight 600
  padding 14px 20px
  letter-spacing 0.01em

.table-view-modal-close.MuiIconButton-root
  color rgba(0, 0, 0, 0.54)
  margin -4px -8px -4px 0

  &:hover
    color rgba(0, 0, 0, 0.87)
    background rgba(0, 0, 0, 0.04)

.table-view-modal-content.MuiDialogContent-root
  display flex
  flex-direction column
  gap 16px
  padding 20px

  // Material UI ships a default `padding-top: 20px !important` on MuiDialogContent
  // when paired with a title in some setups; the value above already matches.

.table-view-modal-actions.MuiDialogActions-root
  padding 12px 20px
  gap 8px

  .MuiButton-root
    text-transform none
    font-weight 500
    border-radius 6px
    padding 4px 14px
    min-width 80px

// The "Add view" footer button on the controller still uses this styl file's
// scope when imported -- keep it nearby.
.table-view-add-button
  flex 1
  display flex
  align-items center
  justify-content center
  gap 6px
  margin 10px 12px
  padding 10px
  cursor pointer
  border-radius 6px
  font-size 13px
  color rgba(0, 0, 0, 0.7)
  background #fafafa
  transition background 150ms ease

  .MuiSvgIcon-root
    width 18px
    height 18px

  &:hover
    background #ececec
    color rgba(0, 0, 0, 0.87)
