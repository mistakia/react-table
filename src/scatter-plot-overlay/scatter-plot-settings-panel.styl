@import '../styles/tokens'

.scatter-plot-settings-panel
  width 100%

.scatter-plot-settings-row
  display flex
  align-items center
  justify-content space-between
  flex-wrap wrap
  gap $rt_space_sm
  padding $rt_space_sm 0
  // Reserve space on the right so toolbar actions don't collide with the
  // absolutely-positioned close button (28px wide, 12px right offset).
  padding-right ($rt_space + 28px + $rt_space_sm)

.scatter-plot-toolbar
  display flex
  align-items center
  gap $rt_space_xs + 2
  flex-wrap wrap

.toolbar-actions
  display flex
  align-items center
  gap $rt_space_xs + 2
  // Subtle separator between the toggle group and the action group.
  padding-left $rt_space_sm
  border-left 1px solid $rt_border_subtle

// Shared sizing for toolbar controls so buttons and selects line up to the
// same vertical center and read as one cohesive control strip.
$toolbar_control_padding_y = 5px
$toolbar_control_padding_x = 12px
$toolbar_control_height = 28px

.toolbar-btn
  display inline-flex
  align-items center
  height $toolbar_control_height
  padding 0 $toolbar_control_padding_x
  border 1px solid transparent
  border-radius $rt_radius_sm
  background-color transparent
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  line-height 1
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition
  white-space nowrap

  &:hover
    border-color $rt_border
    background-color $rt_bg_hover

  &.active
    border-color $rt_border
    background-color $rt_bg_hover

// Right-side action buttons (Settings, Download PNG) carry a persistent
// outline so they read as actions vs the ghost toggle buttons on the left.
.toolbar-action-btn
  border-color $rt_border_subtle
  background-color $rt_bg_subtle
  color $rt_text_muted

  &:hover
    color $rt_text
    border-color $rt_border
    background-color $rt_bg_hover_strong

.toolbar-divider
  display inline-block
  width 1px
  height ($toolbar_control_height - 8px)
  background-color $rt_border_subtle
  margin 0 $rt_space_xs

.toolbar-select-wrap
  display inline-flex
  align-items center
  height $toolbar_control_height
  padding 0 $toolbar_control_padding_x
  border 1px solid transparent
  border-radius $rt_radius_sm
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition

  &:hover
    border-color $rt_border
    background-color $rt_bg_hover

  &:focus-within
    border-color $rt_border
    background-color $rt_bg_hover

.toolbar-select-label
  font-size $rt_font_size_sm
  color $rt_text_muted
  text-transform uppercase
  letter-spacing 0.04em
  margin-right 6px
  white-space nowrap

.toolbar-select
  appearance none
  height auto
  padding 0 16px 0 0
  border 0
  background transparent
  background-image linear-gradient(45deg, transparent 50%, $rt_text_muted 50%), linear-gradient(135deg, $rt_text_muted 50%, transparent 50%)
  background-position calc(100% - 8px) 50%, calc(100% - 4px) 50%
  background-size 4px 4px, 4px 4px
  background-repeat no-repeat
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  line-height 1
  cursor pointer

  &:focus
    outline none

.scatter-plot-settings-modal-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color $rt_bg_overlay
  display flex
  justify-content center
  align-items center
  z-index 3000

.scatter-plot-settings-modal
  background-color $rt_bg
  border-radius $rt_radius_lg
  width 520px
  max-width 95vw
  max-height 85vh
  display flex
  flex-direction column
  box-shadow $rt_shadow_overlay
  border 1px solid $rt_border_subtle

.modal-header
  display flex
  align-items center
  justify-content space-between
  padding $rt_space_lg $rt_space_xl
  border-bottom 1px solid $rt_border_subtle

  .modal-title
    margin 0
    font-size 16px
    font-weight 600
    color $rt_text
    letter-spacing -0.005em

  .modal-close-btn
    background none
    border 1px solid transparent
    border-radius $rt_radius_sm
    font-size 20px
    cursor pointer
    color $rt_text_muted
    line-height 1
    padding 2px 8px
    transition border-color $rt_transition, background-color $rt_transition, color $rt_transition

    &:hover
      color $rt_text
      border-color $rt_border
      background-color $rt_bg_hover

.modal-body
  padding $rt_space_lg $rt_space_xl
  overflow-y auto
  flex 1

.modal-section
  margin-bottom $rt_space_lg

  &:last-child
    margin-bottom 0

.modal-section-label
  display block
  font-size $rt_font_size_sm
  font-weight 600
  color $rt_text_muted
  text-transform uppercase
  letter-spacing 0.05em
  margin-bottom 6px

.modal-text-input,
.modal-textarea,
.modal-select
  width 100%
  box-sizing border-box
  padding 7px 10px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  background-color $rt_bg
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  transition border-color $rt_transition, box-shadow $rt_transition

  &::placeholder
    color $rt_text_disabled

  &:hover:not(:focus)
    border-color rgba(0, 0, 0, 0.4)

  &:focus
    outline none
    border-color $rt_text
    box-shadow 0 0 0 3px rgba(0, 0, 0, 0.06)

.modal-textarea
  resize vertical
  min-height 64px
  line-height 1.4

.modal-footer
  display flex
  justify-content flex-end
  gap $rt_space_sm
  padding $rt_space_lg $rt_space_xl
  border-top 1px solid $rt_border_subtle
  background-color $rt_bg_subtle
  border-radius 0 0 $rt_radius_lg $rt_radius_lg

.modal-btn
  padding 6px 16px
  border 1px solid $rt_border
  border-radius $rt_radius
  font-size $rt_font_size_md
  font-family inherit
  cursor pointer
  background-color $rt_bg
  color $rt_text
  transition background-color $rt_transition, border-color $rt_transition

  &:hover
    background-color $rt_bg_hover

.modal-btn-save
  background-color $rt_bg_subtle
  border-color rgba(0, 0, 0, 0.5)
  font-weight 600

  &:hover
    background-color $rt_bg_hover_strong
    border-color $rt_text

$ref_line_control_height = 26px

.ref-lines-editor
  display flex
  flex-direction column
  gap $rt_space_sm

.ref-lines-table
  width 100%
  border-collapse separate
  border-spacing 0
  font-size $rt_font_size

  th
    text-align left
    font-weight 600
    color $rt_text_muted
    padding $rt_space_xs 6px
    border-bottom 1px solid $rt_border_subtle
    font-size $rt_font_size_sm
    text-transform uppercase
    letter-spacing 0.04em

  td
    padding $rt_space_xs 6px
    vertical-align middle
    border-bottom 1px solid $rt_border_subtle

  .ref-line-row:last-child td
    border-bottom 0

.ref-line-select,
.ref-line-input
  height $ref_line_control_height
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  padding 0 6px
  font-size $rt_font_size
  background-color $rt_bg
  font-family inherit
  color $rt_text
  line-height 1
  box-sizing border-box
  transition border-color $rt_transition, box-shadow $rt_transition

  &:hover:not(:focus)
    border-color rgba(0, 0, 0, 0.4)

  &:focus
    outline none
    border-color $rt_text
    box-shadow 0 0 0 2px rgba(0, 0, 0, 0.06)

.ref-line-select
  cursor pointer

.ref-line-value
  width 80px

.ref-line-label
  width 100%
  box-sizing border-box

.ref-line-color
  width 36px
  height $ref_line_control_height
  padding 0
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  cursor pointer
  background-color $rt_bg
  vertical-align middle
  box-sizing border-box

  // Tighten the inner color swatch padding (varies by browser).
  &::-webkit-color-swatch-wrapper
    padding 2px

  &::-webkit-color-swatch
    border 0
    border-radius 2px

  &::-moz-color-swatch
    border 0
    border-radius 2px

.ref-line-delete
  background none
  border 1px solid transparent
  font-size 16px
  cursor pointer
  color $rt_text_muted
  padding 0 8px
  height $ref_line_control_height
  border-radius $rt_radius_sm
  line-height 1
  transition border-color $rt_transition, background-color $rt_transition, color $rt_transition

  &:hover
    color $rt_text
    border-color $rt_border
    background-color $rt_bg_hover

.ref-line-add-btn
  align-self flex-start
  display inline-flex
  align-items center
  height $ref_line_control_height + 4px
  padding 0 12px
  border 1px dashed $rt_border
  border-radius $rt_radius_sm
  background-color transparent
  font-size $rt_font_size
  font-family inherit
  cursor pointer
  color $rt_text_muted
  transition border-color $rt_transition, background-color $rt_transition, color $rt_transition

  &:hover
    border-style solid
    border-color $rt_text
    background-color $rt_bg_subtle
    color $rt_text
