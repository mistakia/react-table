@import '../styles/tokens'

.scatter-plot-settings-panel
  width 100%

.scatter-plot-settings-row
  display flex
  align-items center
  justify-content space-between
  flex-wrap wrap
  gap $rt_space_sm
  padding $rt_space_sm 0

.scatter-plot-toolbar
  display flex
  align-items center
  gap $rt_space_xs + 2
  flex-wrap wrap

.toolbar-actions
  display flex
  align-items center
  gap $rt_space_xs + 2

.toolbar-btn
  display inline-flex
  align-items center
  padding 6px 12px
  border 1px solid transparent
  border-radius $rt_radius
  background-color transparent
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition
  white-space nowrap

  &:hover
    border-color $rt_border
    background-color $rt_bg_hover

  &.active
    border-color $rt_border
    background-color $rt_bg_hover

.toolbar-select
  padding 6px 8px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  background-color $rt_bg
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  cursor pointer

  &:hover
    background-color $rt_bg_hover

.scatter-plot-settings-modal-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color $rt_bg_overlay
  display flex
  justify-content center
  align-items center
  z-index 3000

.scatter-plot-settings-modal
  background-color $rt_bg
  border-radius $rt_radius_lg
  width 480px
  max-width 95vw
  max-height 80vh
  display flex
  flex-direction column
  box-shadow $rt_shadow_overlay

.modal-header
  display flex
  align-items center
  justify-content space-between
  padding $rt_space_lg $rt_space_xl $rt_space
  border-bottom 1px solid $rt_border_subtle

  .modal-title
    margin 0
    font-size $rt_font_size_md + 2
    font-weight 600
    color $rt_text

  .modal-close-btn
    background none
    border 1px solid transparent
    border-radius $rt_radius_sm
    font-size 20px
    cursor pointer
    color $rt_text_muted
    line-height 1
    padding 2px 6px
    transition border-color $rt_transition, background-color $rt_transition

    &:hover
      border-color $rt_border
      background-color $rt_bg_hover

.modal-body
  padding $rt_space_lg $rt_space_xl
  overflow-y auto
  flex 1

.modal-section
  margin-bottom $rt_space_xl

  &:last-child
    margin-bottom 0

.modal-section-label
  display block
  font-size $rt_font_size
  font-weight 600
  color $rt_text
  margin-bottom 6px

.modal-text-input,
.modal-textarea,
.modal-select
  width 100%
  box-sizing border-box
  padding 6px 8px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  background-color $rt_bg
  color $rt_text
  font-size $rt_font_size
  font-family inherit

  &:focus
    outline none
    border-color $rt_border

.modal-textarea
  resize vertical
  min-height 60px

.modal-footer
  display flex
  justify-content flex-end
  gap $rt_space_sm
  padding $rt_space $rt_space_xl $rt_space_lg
  border-top 1px solid $rt_border_subtle

.modal-btn
  padding 6px 16px
  border 1px solid $rt_border
  border-radius $rt_radius
  font-size $rt_font_size_md
  font-family inherit
  cursor pointer
  background-color $rt_bg
  color $rt_text
  transition background-color $rt_transition, border-color $rt_transition

  &:hover
    background-color $rt_bg_hover

.modal-btn-save
  background-color $rt_bg_subtle
  border-color rgba(0, 0, 0, 0.5)
  font-weight 600

  &:hover
    background-color $rt_bg_hover_strong
    border-color $rt_text

.ref-lines-editor
  display flex
  flex-direction column
  gap $rt_space_sm + 2

.ref-lines-table
  width 100%
  border-collapse collapse
  font-size $rt_font_size

  th
    text-align left
    font-weight 600
    color $rt_text_muted
    padding $rt_space_xs 6px
    border-bottom 1px solid $rt_border_subtle
    font-size $rt_font_size_sm

  td
    padding $rt_space_xs 6px
    vertical-align middle

  .ref-line-row:nth-child(even) td
    background-color $rt_bg_subtle

.ref-line-select
  padding 3px 6px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  font-size $rt_font_size
  background-color $rt_bg
  font-family inherit
  cursor pointer

.ref-line-input
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  padding 3px 6px
  font-size $rt_font_size
  background-color $rt_bg
  font-family inherit

  &:focus
    outline none
    border-color $rt_border

.ref-line-value
  width 80px

.ref-line-label
  width 100%
  box-sizing border-box

.ref-line-color
  width 36px
  height 28px
  padding 1px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  cursor pointer
  background-color $rt_bg

.ref-line-delete
  background none
  border 1px solid transparent
  font-size 16px
  cursor pointer
  color $rt_text_muted
  padding 2px 6px
  border-radius $rt_radius_sm
  line-height 1
  transition border-color $rt_transition, background-color $rt_transition

  &:hover
    border-color $rt_border
    background-color $rt_bg_hover

.ref-line-add-btn
  align-self flex-start
  padding 5px 12px
  border 1px solid transparent
  border-radius $rt_radius
  background-color $rt_bg_subtle
  font-size $rt_font_size
  font-family inherit
  cursor pointer
  color $rt_text_muted
  transition border-color $rt_transition, background-color $rt_transition

  &:hover
    border-color $rt_border
    background-color $rt_bg_hover_strong
    color $rt_text
