@import '../styles/tokens'

.scatter-plot-settings-panel
  width 100%

.scatter-plot-settings-row
  display flex
  align-items center
  justify-content space-between
  flex-wrap wrap
  gap $rt_space_sm
  padding $rt_space_sm 0

.scatter-plot-toolbar
  display flex
  align-items center
  gap $rt_space_xs + 2
  flex-wrap wrap

.toolbar-actions
  display flex
  align-items center
  gap $rt_space_xs + 2

// !important on the reset properties below is intentional: consumer apps
// frequently ship a global `button:not(...)` rule (e.g. league) whose specificity
// (0,5,1) beats our class-based selector. Rather than chain a deep parent
// selector for every property, we !important the handful of resets that conflict.
.toolbar-btn
  display inline-flex !important
  align-items center !important
  height auto !important
  padding 6px 12px !important
  border 1px solid transparent !important
  border-radius $rt_radius !important
  background transparent !important
  color $rt_text !important
  font-size $rt_font_size !important
  font-family inherit !important
  font-weight normal !important
  text-transform none !important
  letter-spacing normal !important
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition
  white-space nowrap

  &:hover,
  &:hover:not(:disabled),
  &:hover:not([disabled])
    border-color $rt_border !important
    background-color $rt_bg_hover !important

  &.active
    color $rt_text !important
    border-color $rt_border !important
    background-color $rt_bg_hover !important

.toolbar-select
  padding 6px 8px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  background-color $rt_bg
  color $rt_text
  font-size $rt_font_size
  font-family inherit
  cursor pointer

  &:hover
    background-color $rt_bg_hover

.scatter-plot-settings-modal-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color $rt_bg_overlay
  display flex
  justify-content center
  align-items center
  z-index 3000

.scatter-plot-settings-modal
  background-color $rt_bg
  border-radius $rt_radius_lg
  width 480px
  max-width 95vw
  max-height 80vh
  display flex
  flex-direction column
  box-shadow $rt_shadow_overlay

.modal-header
  display flex
  align-items center
  justify-content space-between
  padding $rt_space_lg $rt_space_xl $rt_space
  border-bottom 1px solid $rt_border_subtle

  .modal-title
    margin 0
    font-size $rt_font_size_md + 2
    font-weight 600
    color $rt_text

  .modal-close-btn
    height auto !important
    background none !important
    border 1px solid transparent !important
    border-radius $rt_radius_sm !important
    font-size 20px !important
    font-family inherit !important
    text-transform none !important
    letter-spacing normal !important
    color $rt_text_muted !important
    line-height 1
    padding 2px 6px !important
    cursor pointer
    transition border-color $rt_transition, background-color $rt_transition

    &:hover,
    &:hover:not(:disabled),
    &:hover:not([disabled])
      border-color $rt_border !important
      background-color $rt_bg_hover !important

.modal-body
  padding $rt_space_lg $rt_space_xl
  overflow-y auto
  flex 1

.modal-section
  margin-bottom $rt_space_xl

  &:last-child
    margin-bottom 0

.modal-section-label
  display block
  font-size $rt_font_size
  font-weight 600
  color $rt_text
  margin-bottom 6px

.modal-text-input,
.modal-textarea,
.modal-select
  width 100%
  box-sizing border-box
  padding 6px 8px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  background-color $rt_bg
  color $rt_text
  font-size $rt_font_size
  font-family inherit

  &:focus
    outline none
    border-color $rt_border

.modal-textarea
  resize vertical
  min-height 60px

.modal-footer
  display flex
  justify-content flex-end
  gap $rt_space_sm
  padding $rt_space $rt_space_xl $rt_space_lg
  border-top 1px solid $rt_border_subtle

.modal-btn
  display inline-flex !important
  align-items center !important
  height auto !important
  padding 6px 16px !important
  border 1px solid $rt_border !important
  border-radius $rt_radius !important
  font-size $rt_font_size_md !important
  font-family inherit !important
  font-weight normal !important
  text-transform none !important
  letter-spacing normal !important
  background $rt_bg !important
  color $rt_text !important
  cursor pointer
  transition background-color $rt_transition, border-color $rt_transition

  &:hover,
  &:hover:not(:disabled),
  &:hover:not([disabled])
    background-color $rt_bg_hover !important

.modal-btn-save
  background $rt_bg_subtle !important

  &:hover,
  &:hover:not(:disabled),
  &:hover:not([disabled])
    background-color $rt_bg_hover_strong !important

.ref-lines-editor
  display flex
  flex-direction column
  gap $rt_space_sm + 2

.ref-lines-table
  width 100%
  border-collapse collapse
  font-size $rt_font_size

  th
    text-align left
    font-weight 600
    color $rt_text_muted
    padding $rt_space_xs 6px
    border-bottom 1px solid $rt_border_subtle
    font-size $rt_font_size_sm

  td
    padding $rt_space_xs 6px
    vertical-align middle

  .ref-line-row:nth-child(even) td
    background-color $rt_bg_subtle

.ref-line-select
  padding 3px 6px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  font-size $rt_font_size
  background-color $rt_bg
  font-family inherit
  cursor pointer

.ref-line-input
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  padding 3px 6px
  font-size $rt_font_size
  background-color $rt_bg
  font-family inherit

  &:focus
    outline none
    border-color $rt_border

.ref-line-value
  width 80px

.ref-line-label
  width 100%
  box-sizing border-box

.ref-line-color
  width 36px
  height 28px
  padding 1px
  border 1px solid $rt_border
  border-radius $rt_radius_sm
  cursor pointer
  background-color $rt_bg

.ref-line-delete
  height auto !important
  background none !important
  border 1px solid transparent !important
  font-size 16px !important
  font-family inherit !important
  text-transform none !important
  letter-spacing normal !important
  color $rt_text_muted !important
  padding 2px 6px !important
  border-radius $rt_radius_sm !important
  line-height 1
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition

  &:hover,
  &:hover:not(:disabled),
  &:hover:not([disabled])
    border-color $rt_border !important
    background-color $rt_bg_hover !important

.ref-line-add-btn
  align-self flex-start
  display inline-flex !important
  align-items center !important
  height auto !important
  padding 5px 12px !important
  border 1px solid transparent !important
  border-radius $rt_radius !important
  background $rt_bg_subtle !important
  font-size $rt_font_size !important
  font-family inherit !important
  font-weight normal !important
  text-transform none !important
  letter-spacing normal !important
  color $rt_text_muted !important
  cursor pointer
  transition border-color $rt_transition, background-color $rt_transition

  &:hover,
  &:hover:not(:disabled),
  &:hover:not([disabled])
    border-color $rt_border !important
    background-color $rt_bg_hover_strong !important
    color $rt_text !important
