.scatter-plot-settings-panel
  width 100%

.scatter-plot-settings-row
  display flex
  align-items center
  justify-content space-between
  flex-wrap wrap
  gap 8px
  padding 8px 0

.scatter-plot-toolbar
  display flex
  align-items center
  gap 6px
  flex-wrap wrap

.toolbar-actions
  display flex
  align-items center
  gap 6px

.toolbar-btn
  display inline-flex
  align-items center
  padding 6px 12px
  border 1px solid rgba(0, 0, 0, 0.23)
  border-radius 6px
  background-color white
  font-size 13px
  cursor pointer
  transition border-color 150ms ease, box-shadow 150ms ease, background-color 150ms ease
  white-space nowrap

  &:hover
    border-color rgba(0, 0, 0, 0.45)
    box-shadow $box_shadow

  &.active
    background-color #e8f0fe
    border-color #1a73e8
    color #1a73e8

.toolbar-select
  padding 6px 8px
  border 1px solid rgba(0, 0, 0, 0.23)
  border-radius 6px
  background-color white
  font-size 13px
  cursor pointer

  &:hover
    border-color rgba(0, 0, 0, 0.45)

// Modal overlay
.scatter-plot-settings-modal-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color rgba(0, 0, 0, 0.4)
  display flex
  justify-content center
  align-items center
  z-index 3000

.scatter-plot-settings-modal
  background-color white
  border-radius 8px
  width 480px
  max-width 95vw
  max-height 80vh
  display flex
  flex-direction column
  box-shadow 0 8px 32px rgba(0, 0, 0, 0.18)

.modal-header
  display flex
  align-items center
  justify-content space-between
  padding 16px 20px 12px
  border-bottom 1px solid #eee

  .modal-title
    margin 0
    font-size 16px
    font-weight 600

  .modal-close-btn
    background none
    border none
    font-size 20px
    cursor pointer
    color #555
    line-height 1
    padding 2px 6px
    border-radius 4px

    &:hover
      color #222
      background-color #f0f0f0

.modal-body
  padding 16px 20px
  overflow-y auto
  flex 1

.modal-section
  margin-bottom 20px

  &:last-child
    margin-bottom 0

.modal-section-label
  display block
  font-size 13px
  font-weight 600
  color #333
  margin-bottom 6px

.modal-placeholder
  font-size 13px
  color #999
  margin 0
  font-style italic

.modal-footer
  display flex
  justify-content flex-end
  gap 8px
  padding 12px 20px 16px
  border-top 1px solid #eee

.modal-btn
  padding 7px 18px
  border-radius 6px
  font-size 14px
  cursor pointer
  transition background-color 150ms ease

.modal-btn-cancel
  background-color white
  border 1px solid rgba(0, 0, 0, 0.23)
  color #333

  &:hover
    background-color #f5f5f5

.modal-btn-save
  background-color #1a73e8
  border 1px solid #1a73e8
  color white

  &:hover
    background-color #1558b0
