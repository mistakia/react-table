@import '../styles/tokens'

.scatter-plot-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color $rt_bg_overlay
  display flex
  justify-content center
  align-items flex-start
  padding $rt_space_xl 0
  z-index 2000
  overflow-y auto

  .scatter-plot-container
    background-color $rt_bg
    padding $rt_space_xl
    border-radius $rt_radius_lg
    width 80%
    height fit-content
    position relative

    .highcharts-data-label
      z-index 1

    .highcharts-tooltip
      z-index 2

    .scatter-plot-close-button
      position absolute
      top $rt_space
      right $rt_space
      z-index 1
      width 28px
      height 28px
      display inline-flex
      align-items center
      justify-content center
      background none
      border 1px solid transparent
      border-radius $rt_radius_sm
      font-size 18px
      line-height 1
      color $rt_text_muted
      cursor pointer
      transition border-color $rt_transition, background-color $rt_transition

      &:hover
        border-color $rt_border
        background-color $rt_bg_hover

.regression-stats
  margin-top $rt_space
  padding $rt_space_lg
  background-color $rt_bg_subtle
  border 1px solid $rt_border_subtle
  border-radius $rt_radius_sm

  h4
    margin-top 0
    margin-bottom $rt_space_sm

  div
    margin-bottom $rt_space_xs
