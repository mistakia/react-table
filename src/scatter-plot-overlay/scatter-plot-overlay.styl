@import '../styles/tokens'

.scatter-plot-overlay
  position fixed
  top 0
  left 0
  right 0
  bottom 0
  background-color $rt_bg_overlay
  display flex
  justify-content center
  align-items flex-start
  padding $rt_space_xl 0
  z-index 2000
  overflow-y auto

  .scatter-plot-container
    background-color $rt_bg
    padding $rt_space_xl
    border-radius $rt_radius_lg
    width 80%
    height fit-content
    position relative

    .highcharts-data-label
      z-index 1

    .highcharts-tooltip
      z-index 2

    .scatter-plot-close-button
      position absolute
      top $rt_space
      right $rt_space
      z-index 1
      width 28px !important
      height 28px !important
      min-width 0 !important
      display inline-flex !important
      align-items center !important
      justify-content center !important
      padding 0 !important
      background none !important
      border 1px solid transparent !important
      border-radius $rt_radius_sm !important
      font-size 18px !important
      font-family inherit !important
      text-transform none !important
      letter-spacing normal !important
      line-height 1 !important
      color $rt_text_muted !important
      cursor pointer
      transition border-color $rt_transition, background-color $rt_transition

      &:hover,
      &:hover:not(:disabled),
      &:hover:not([disabled])
        border-color $rt_border !important
        background-color $rt_bg_hover !important

.regression-stats
  margin-top $rt_space
  padding $rt_space_lg
  background-color $rt_bg_subtle
  border 1px solid $rt_border_subtle
  border-radius $rt_radius_sm

  h4
    margin-top 0
    margin-bottom $rt_space_sm

  div
    margin-bottom $rt_space_xs
