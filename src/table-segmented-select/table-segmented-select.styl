.table-segmented-select
  display flex
  align-items stretch
  height 36px
  border 1px solid rgba(0, 0, 0, 0.23)
  border-radius 4px
  overflow hidden
  flex-shrink 0

  .table-segmented-select-option
    display flex
    align-items center
    padding 0 12px
    font-size 13px
    cursor pointer
    user-select none
    background-color #fff
    color rgba(0, 0, 0, 0.6)

    &:hover
      background-color rgba(0, 0, 0, 0.04)

    &.-active
      background-color rgba(25, 118, 210, 0.12)
      color #1976d2
      cursor default

    & + .table-segmented-select-option
      border-left 1px solid rgba(0, 0, 0, 0.23)
