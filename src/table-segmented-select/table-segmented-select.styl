@import '../styles/tokens.styl'

.table-segmented-select
  display inline-flex
  align-items center
  height 35px
  padding 0 $rt_space_xs
  gap 2px
  border 1px solid transparent
  border-radius $rt_radius_sm
  user-select none
  cursor pointer
  transition border-color $rt_transition, background $rt_transition

  &:hover
    border 1px solid $rt_modal_border
    background #fff

  .table-segmented-select-options
    display inline-flex
    align-items center
    height 100%
    gap 2px

  .table-segmented-select-option
    display inline-flex
    align-items center
    height 24px
    padding 0 $rt_space_sm
    border-radius $rt_radius_sm
    font-size $rt_font_size_sm
    font-weight 500
    color $rt_text_muted
    transition background $rt_transition, color $rt_transition

    &:hover
      color $rt_text

    &.-active
      background $rt_accent_subtle
      color $rt_accent_text
      font-weight 600
      cursor default
