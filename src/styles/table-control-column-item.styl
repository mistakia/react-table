@import './tokens.styl'

.column-item
  position relative
  display flex
  align-items center
  user-select none
  border-radius $rt_radius_sm
  font-size $rt_font_size_md
  min-height $rt_row_height
  padding 0 $rt_space_sm
  flex-wrap wrap
  border 1px solid transparent

  &.column-expanded
  &.more-menu-open
  &.column-select-open
    border 1px solid $rt_border_subtle
    background $rt_bg_selected

  &.prefix
    background $rt_bg_subtle

  &.shown
    background $rt_active_bg
    box-shadow inset 2px 0 0 0 $rt_active_bar

  .column-name
    flex 1
    font-family "Roboto","Helvetica","Arial",sans-serif
    font-weight 400
    font-size $rt_font_size_md
    line-height 1.4
    letter-spacing 0.00938em
    color $rt_text
    border 1px solid transparent
    border-radius $rt_radius_sm
    margin $rt_space_xs 0
    padding 0 $rt_space 0 $rt_space_xs
    position relative

  .column-category
    font-family IBM Plex Mono,monospace

  .column-data-type
    display flex
    align-items center
    justify-content center
    margin-left $rt_space_sm
    margin-right $rt_space_xs
    color $rt_text_muted

    svg
      width 16px
      height 16px

.selected-columns-container
  .column-name::after
    content '\270E'
    position absolute
    right $rt_space_xs
    top 50%
    transform translateY(-50%) scaleX(-1)
    font-size 16px
    color $rt_accent
    opacity 0
  .column-item
    background $rt_bg_subtle

.column-actions
  display flex
  align-items center

@media (pointer:fine)
  .selected-columns-container .column-name
    cursor pointer

    &:hover
      border 1px solid $rt_accent
      background $rt_accent_subtle

      &::after
        opacity 1

  .column-item
    .column-action
      opacity 0
      transition opacity $rt_transition

    &.-row-clickable
      cursor pointer

    &:hover
      background $rt_bg_hover

      .column-action
        opacity 1
        transition opacity $rt_transition

@media (max-width 601px)
  .column-item
    justify-content flex-end
