.base-Popper-root.table-popper
.MuiPopper-root.table-popper
    z-index 1299
    border-radius 6px
    background white
    position relative
    box-shadow $box_shadow
    display flex
    flex-direction column
    max-width calc(100vw - 24px)
    max-height 70vh
    min-width 260px
    overflow hidden
    border 1px solid $borderColor

.base-Popper-root.table-popper:has(.rt-popper-surface)
.MuiPopper-root.table-popper:has(.rt-popper-surface)
    border 0
    border-radius 0
    background transparent
    box-shadow none
    overflow visible
