@import './tokens.styl'

.rt-popper-surface
  background $rt_bg
  border 1px solid $rt_modal_border
  border-radius $rt_radius_lg
  box-shadow $rt_modal_shadow
  overflow hidden

.selected-columns-parameters-header
  font-size $rt_font_size_sm
  font-weight 600
  letter-spacing 0.02em
  text-transform uppercase
  color $rt_text
  background $rt_bg_subtle
  position sticky
  top 0
  z-index 2
  padding $rt_space_sm $rt_space
