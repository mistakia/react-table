{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mistakia.github.io/react-table/schema/view/view.json",
  "title": "View",
  "type": "object",
  "properties": {
    "view_id": {
      "type": "string",
      "description": "Unique identifier for the view"
    },
    "view_name": {
      "type": "string",
      "description": "Display name of the view"
    },
    "view_description": {
      "type": "string",
      "description": "Description of the view"
    },
    "view_username": {
      "type": "string",
      "description": "Username of the view creator"
    },
    "search": {
      "type": "object",
      "description": "Search adapter configuration. The 'type' field selects the registered adapter; remaining fields are adapter-specific (e.g. column_id for 'where', fields for 'client', entity_type for 'server_q').",
      "properties": {
        "type": {
          "type": "string",
          "description": "Registered adapter id"
        },
        "column_id": {
          "type": "string",
          "description": "Target column for the 'where' adapter"
        },
        "operator": {
          "type": "string",
          "description": "Optional override operator for the 'where' adapter (defaults to ILIKE)"
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fields to scan for the 'client' adapter"
        },
        "key_field": {
          "type": "string",
          "description": "Row primary-key field for highlight maps produced by the 'client' adapter"
        },
        "entity_type": {
          "type": "string",
          "description": "Entity type for the 'server_q' adapter"
        }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "view_filters": {
      "type": "array",
      "items": { "$ref": "../state/column-reference.json" },
      "description": "Quick filter columns for this view"
    },
    "table_state": {
      "$ref": "../state/table-state.json",
      "description": "Table state configuration for this view"
    },
    "user_id": { "type": "string", "description": "Owner user ID of the view" },
    "saved_table_state": {
      "$ref": "../state/table-state.json",
      "description": "Persisted table state for comparison"
    }
  }
}
